#!/bin/bash
# YunoHost app install script for MISP (Docker/Compose)
set -euo pipefail

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME

# Read settings from manifest/settings (those provided by the user)
export domain=$(ynh_app_setting_get --app=$app --key=domain)
export subpath=$(ynh_app_setting_get --app=$app --key=subpath)
is_public=$(ynh_app_setting_get --app=$app --key=is_public)
export admin_email=$(ynh_app_setting_get --app=$app --key=admin_email)
export admin_password=$(ynh_app_setting_get --app=$app --key=admin_password)
export admin_org=$(ynh_app_setting_get --app=$app --key=admin_org)

export misp_version=$(ynh_app_setting_get --app=$app --key=misp_version)
export modules_version=$(ynh_app_setting_get --app=$app --key=modules_version)

# Generate or retrieve secrets
db_root_password=$(ynh_app_setting_get --app=$app --key=db_root_password)
if [ -z "$db_root_password" ]; then
    db_root_password=$(ynh_string_random --length=32)
    ynh_app_setting_set --app=$app --key=db_root_password --value="$db_root_password"
fi
export db_root_password

db_password=$(ynh_app_setting_get --app=$app --key=db_password)
if [ -z "$db_password" ]; then
    db_password=$(ynh_string_random --length=32)
    ynh_app_setting_set --app=$app --key=db_password --value="$db_password"
fi
export db_password

redis_password=$(ynh_app_setting_get --app=$app --key=redis_password)
if [ -z "$redis_password" ]; then
    redis_password=$(ynh_string_random --length=32)
    ynh_app_setting_set --app=$app --key=redis_password --value="$redis_password"
fi
export redis_password

export enable_db_settings=$(ynh_app_setting_get --app=$app --key=enable_db_settings)

export upload_limit_mb=$(ynh_app_setting_get --app=$app --key=upload_limit_mb)

export install_dir=$(ynh_app_setting_get --app=$app --key=install_dir)
export data_dir=$(ynh_app_setting_get --app=$app --key=data_dir)

# Pick an internal localhost port
export app_port=$(ynh_find_port --port=18080)
ynh_app_setting_set --app=$app --key=app_port --value=$app_port

ynh_print_info "-- Preflight checks"
ynh_check_root
ynh_validate_domain_path --domain=$domain --path=$subpath
ynh_script_progression --message="Installing required packages (docker, compose)..." --weight=1
ynh_install_app_dependencies

# Warn on low RAM
total_kb=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
if [[ $total_kb -lt 6291456 ]]; then
  ynh_print_warn "MISP benefits from >=8GB RAM in production. You have <6GB; okay for testing."
fi

ynh_script_progression --message="Creating system user and directories..." --weight=1
ynh_system_user_create --username=$app --home_dir="$install_dir"
mkdir -p "$install_dir" "$data_dir"/{db,redis,misp}
chown -R "$app":"$app" "$install_dir" "$data_dir"

ynh_script_progression --message="Rendering configurations..." --weight=1
# Convert boolean for compose template
if [[ "$enable_db_settings" == "1" ]]; then
  export enable_db_settings_bool="true"
else
  export enable_db_settings_bool="false"
fi

# Use ynh_add_config for automatic Jinja2 substitution
ynh_add_config --template="conf/docker-compose.yml.j2" --destination="$install_dir/docker-compose.yml"
ynh_add_config --template="conf/nginx.conf.j2" --destination="/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_script_progression --message="Starting containers..." --weight=2
pushd "$install_dir" >/dev/null
docker compose pull
docker compose up -d
popd >/dev/null

ynh_script_progression --message="Waiting for MISP to respond..." --weight=2
# Wait up to 5 minutes
timeout=300
start_time=$(date +%s)
while true; do
  if curl -sf "http://127.0.0.1:${app_port}/" >/dev/null; then
    ynh_print_info "MISP is up!"
    break
  fi

  current_time=$(date +%s)
  elapsed=$((current_time - start_time))
  if [[ $elapsed -gt $timeout ]]; then
    ynh_die "MISP failed to start within $timeout seconds."
  fi

  sleep 5
done

ynh_script_progression --message="Configuring permissions..." --weight=2
ynh_permission_url --permission="main" --url="$subpath"
if [[ "$is_public" == "1" ]]; then
  ynh_permission_update --permission="main" --add="visitors"
else
  ynh_permission_update --permission="main" --add="all_users"
fi

ynh_script_progression --message="Reloading Nginx..." --weight=1
ynh_systemctl --service nginx --action reload

ynh_script_progression --message="Install complete." --last
