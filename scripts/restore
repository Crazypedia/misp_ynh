#!/bin/bash
# YunoHost app restore script for MISP (Docker/Compose)
set -euo pipefail

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME

ynh_check_root

install_dir=$(ynh_app_setting_get --app=$app --key=install_dir)
data_dir=$(ynh_app_setting_get --app=$app --key=data_dir)

ynh_script_progression --message="Restoring files and data..." --weight=2
ynh_restore --src_path="$install_dir"
ynh_restore --src_path="$data_dir"

ynh_script_progression --message="Starting MISP services..." --weight=2
if [ -d "$install_dir" ]; then
  pushd "$install_dir" >/dev/null
  docker compose up -d
  popd >/dev/null
fi
